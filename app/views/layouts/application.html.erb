<!DOCTYPE html>
<html>
  <head>
    <title>Spendless</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="main-header">
      <nav class="navbar">
        <%= link_to dashboards_path, class: "brand" do %>
          Spend<span>less</span>
        <% end %>

        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div class="nav-links" id="nav-menu">
          <% if user_signed_in? || current_user&.guest? %>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_users_path, class: "nav-item" %>
            <% end %>
            <%= link_to "Dashboard", dashboards_path, class: "nav-item" %>
            <%= link_to "Expenses", expenses_path, class: "nav-item" %>
            <%= link_to "Categories", categories_path, class: "nav-item" %>
            <%= link_to "Budget", budgets_path, class: "nav-item" %>
            <% if !current_user.guest? %>
              <%= link_to "Profile", user_path(current_user), class: "nav-item" %>
              <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-item logout" %>
            <% else %>
              <span class="nav-item text-warning">Demo mode</span>
              <%= link_to "Login", new_user_session_path, class: "nav-item" %>
              <% if current_user&.guest? %>
                <%= link_to "Exit Demo", guest_session_path, data: { turbo_method: :delete }, class: "nav-item logout" %>
              <% end %>
            <% end %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "nav-item" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "nav-item signup" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="container">
      <% if current_user&.guest? %>
        <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center">
          <span class="me-2">ℹ️</span>
          <div>
            <strong>Demo Mode:</strong> You are exploring as a guest. To save your own data, 
            <%= link_to "Create an Account", new_user_registration_path, class: "text-decoration-underline" %>.
          </div>
        </div>
      <% end %>
      <% if flash[:notice] %>
        <div class="flash notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash alert"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="main-footer">
      <p>&copy; <%= Time.now.year %> Obunde Tech LTD</p>
    </footer>
  </body>
</html>