<%# app/views/users/edit.html.erb %>
<h2>Edit Profile</h2>

<%= form_with model: @user do |f| %>
  <% if @user.errors.any? %>
    <div>
      <% @user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :email %>
    <%= f.email_field :email %>
  </div>

  <%= f.submit "Update Profile" %>
  <%= link_to "Back", user_path(@user) %>
<% end %>