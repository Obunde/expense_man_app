<div class="page-header mb-4">
  <h3>My Profile</h3>
</div>

<div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
  <div class="card-body p-0">
    <div class="text-center py-5 bg-light border-bottom">
      <div class="avatar-circle mx-auto mb-3">
        <%= @user.name.first.upcase if @user.name.present? %>
      </div>
      <h4 class="mb-1 text-dark"><%= @user.name %></h4>
      <p class="text-muted small mb-0">Member since <%= @user.created_at.strftime("%b %Y") %></p>
    </div>

    <div class="p-4">
      <div class="row mb-3 border-bottom pb-3">
        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Email Address</div>
        <div class="col-sm-8 text-dark"><%= @user.email %></div>
      </div>
      
      <div class="row mb-3 border-bottom pb-3">
        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Account Type</div>
        <div class="col-sm-8">
          <span class="category-badge px-2 py-1">
            <%= @user.admin? ? "Administrator" : "Standard User" %>
          </span>
        </div>
      </div>

      <div class="text-center mt-4 pt-2">
        <%= link_to "Edit Profile Settings", edit_user_path(@user), class: "btn-primary btn-sm px-4" %>
      </div>
    </div>
  </div>
</div>