<%# app/views/users/show.html.erb %>
<h2>My Profile</h2>

<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<div>
  <p><strong>Name:</strong> <%= @user.name %></p>
  <p><strong>Email:</strong> <%= @user.email %></p>
  <p><strong>Member since:</strong> <%= @user.created_at.strftime("%B %d, %Y") %></p>
</div>

<%= link_to "Edit Profile", edit_user_path(@user) %>