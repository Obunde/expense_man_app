<%# app/views/expenses/index.html.erb %>
<h2>Expenses</h2>

<!-- Search and Filter -->
<%= form_with url: expenses_path, method: :get do |f| %>
  <div>
    <%= f.label :date, "Filter by Date" %>
    <%= f.date_field :date, value: params[:date] %>
  </div>

  <div>
    <%= f.label :category_id, "Filter by Category" %>
    <%= f.select :category_id,
        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
        { include_blank: "All Categories" } %>
  </div>

  <%= f.submit "Filter" %>
  <%= link_to "Clear", expenses_path %>
<% end %>

<%= link_to "New Expense", new_expense_path %>

<% if @expenses.any? %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Amount</th>
        <th>Category</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @expenses.each do |expense| %>
        <tr>
          <td><%= expense.title %></td>
          <td><%= expense.amount %></td>
          <td><%= expense.category.name %></td>
          <td><%= expense.expense_date %></td>
          <td>
            <%= link_to "Edit", edit_expense_path(expense) %>
            <%= link_to "View", expense_path(expense) %>
            <%= link_to "Delete", expense_path(expense),
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No expenses found.</p>
<% end %>