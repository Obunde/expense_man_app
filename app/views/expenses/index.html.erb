<div class="page-header">
  <h2>Expenses</h2>
  <%= link_to "New Expense", new_expense_path, class: "btn-primary" %>
</div>

<section class="filter-section">
  <%= form_with url: expenses_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-group">
      <%= f.date_field :date, value: params[:date], class: "form-control-sm" %>
      <%= f.select :category_id, 
            options_from_collection_for_select(@categories, :id, :name, params[:category_id]), 
            { include_blank: "All Categories" }, class: "form-control-sm" %>
      <%= f.submit "Filter", class: "btn-secondary btn-sm" %>
      <%= link_to "Clear", expenses_path, class: "text-link" if params[:date].present? || params[:category_id].present? %>
    </div>
  <% end %>
</section>

<% if @expenses.any? %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Amount</th>
        <th>Category</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @expenses.each do |expense| %>
        <tr>
          <td><%= expense.title %></td>
          <td><strong><%= number_to_currency(expense.amount) %></strong></td>
          <td><span class="category-badge"><%= expense.category.name %></span></td>
          <td><%= expense.expense_date.strftime("%d/%m/%Y") %></td>
          <td>
            <div class="table-actions">
              <%= link_to "View", expense_path(expense), class: "btn-sm btn-secondary" %>
              <%= link_to "Edit", edit_expense_path(expense), class: "btn-sm btn-secondary" %>
              <%= link_to "Delete", expense_path(expense), 
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, 
                  class: "btn-sm btn-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state">
    <p>No expenses found. Try adjusting your filters or add a new one!</p>
  </div>
<% end %>