<%# app/views/expenses/edit.html.erb %>
<h2>Edit Expense</h2>

<%= form_with model: @expense do |f| %>
  <% if @expense.errors.any? %>
    <div>
      <% @expense.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :amount %>
    <%= f.number_field :amount %>
  </div>

  <div>
    <%= f.label :expense_date, "Date" %>
    <%= f.date_field :expense_date %>
  </div>

  <div>
    <%= f.label :category_id, "Category" %>
    <%= f.select :category_id,
        options_from_collection_for_select(@categories, :id, :name, @expense.category_id),
        { include_blank: "Select a category" } %>
  </div>

  <%= f.submit "Update Expense" %>
  <%= link_to "Back", expenses_path %>
<% end %>