<%= form_with model: expense, class: "spendless-form" do |f| %>
  <% if expense.errors.any? %>
    <div class="flash alert">
      <h4><%= pluralize(expense.errors.count, "error") %> prohibited this expense from being saved:</h4>
      <ul>
        <% expense.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, placeholder: "e.g. Groceries" %>
  </div>

  <div class="form-group">
    <%= f.label :amount %>
    <%= f.number_field :amount, step: 0.01, placeholder: "0.00" %>
  </div>

  <div class="form-group">
    <%= f.label :expense_date, "Date" %>
    <%= f.date_field :expense_date %>
  </div>

  <div class="form-group">
    <%= f.label :category_id, "Category" %>
    <%= f.select :category_id, 
          options_from_collection_for_select(categories, :id, :name, expense.category_id), 
          { include_blank: "Select a category" } %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn-primary" %>
    <%= link_to "Cancel", expenses_path, class: "btn-secondary" %>
  </div>
<% end %>