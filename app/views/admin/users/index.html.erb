<%# app/views/admin/users/index.html.erb %>
<h2>Spendless Admin</h2>

<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<div>
  <h3>Users</h3>

  <% if @users.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Member Since</th>
          <th>Expenses</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.created_at.strftime("%B %d, %Y") %></td>
            <td><%= user.expenses.count %></td>
            <td>
              <%= link_to "Delete", admin_user_path(user),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this user?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No users found.</p>
  <% end %>
</div>