<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h3>User Record</h3>
  <%= link_to "Back to List", admin_users_path, class: "btn-secondary btn-sm" %>
</div>

<div class="card shadow-sm border-0 mx-auto" style="max-width: 650px;">
  <div class="card-body p-0">
    <div class="p-4 border-bottom bg-light">
      <h5 class="mb-1"><%= @user.name %></h5>
      <p class="text-muted mb-0"><%= @user.email %></p>
    </div>

    <div class="p-4">
      <div class="row py-2 border-bottom">
        <div class="col-sm-5 text-muted small fw-bold text-uppercase">Admin Access</div>
        <div class="col-sm-7"><%= @user.admin? ? "✅ Granted" : "❌ No" %></div>
      </div>
      <div class="row py-2 border-bottom">
        <div class="col-sm-5 text-muted small fw-bold text-uppercase">Expenses Logged</div>
        <div class="col-sm-7"><span class="badge bg-light text-dark border"><%= @user.expenses.count %> records</span></div>
      </div>
      <div class="row py-2">
        <div class="col-sm-5 text-muted small fw-bold text-uppercase">Joined Spendless</div>
        <div class="col-sm-7"><%= @user.created_at.strftime("%B %d, %Y") %></div>
      </div>
    </div>

    <div class="p-3 bg-light text-center border-top">
      <%= link_to "Edit User Privileges", edit_admin_user_path(@user), class: "btn-primary btn-sm px-4" %>
    </div>
  </div>
</div>