<div class="page-header mb-4">
  <h3>Manage Categories</h3>
</div>

<div class="row g-4">
  <% unless current_user.guest? %>
    <div class="col-md-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h5 class="card-title mb-3 text-success">Add Category</h5>
          <%= render "form", category: @category %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="<%= current_user.guest? ? 'col-md-12' : 'col-md-7' %>">
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="p-3 border-bottom">
          <h5 class="card-title mb-0">Existing Categories</h5>
        </div>

        <% if @categories.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <thead class="bg-light">
                <tr>
                  <th class="ps-4 py-3 text-muted small text-uppercase">Category Name</th>
                  <th class="pe-4 py-3 text-end text-muted small text-uppercase">Action</th>
                </tr>
              </thead>
              <tbody>
                <% @categories.each do |category| %>
                  <tr>
                    <td class="ps-4">
                      <span class="category-badge px-3 py-1"><%= category.name %></span>
                    </td>
                    <td class="pe-4 text-end">
                      <%= link_to "Edit", edit_category_path(category), class: "btn-secondary btn-sm px-3" %>
                      <%= link_to "Delete", category_path(category),
                          data: { turbo_method: :delete, turbo_confirm: "Delete this category and all its linked expenses?" },
                          class: "btn-danger btn-sm px-3" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-4 text-center">
            <p class="text-muted mb-0">No categories created yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>