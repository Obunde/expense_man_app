<%# app/views/dashboard/index.html.erb %>
<h2>Dashboard</h2>

<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<!-- Monthly Summary -->
<div>
  <h3>Monthly Summary — <%= Date::MONTHNAMES[Date.current.month] %> <%= Date.current.year %></h3>

  <p>Total Spending this month: <%= @total_spending %></p>

  <% if @budget %>
    <p>Monthly Budget: <%= @budget.monthly_limit %></p>
    <p>Remaining: <%= @budget.monthly_limit - @total_spending %></p>

    <% if @total_spending > @budget.monthly_limit %>
      <p style="color:red;">⚠️ You have exceeded your monthly budget!</p>
    <% elsif @total_spending >= @budget.monthly_limit * 0.9 %>
      <p style="color:orange;">⚠️ You are close to exceeding your monthly budget!</p>
    <% end %>
  <% else %>
    <p>No budget set for this month. <%= link_to "Set a budget", new_budget_path %></p>
  <% end %>
</div>

<!-- Recent Expenses -->
<div>
  <h3>Recent Expenses</h3>

  <% if @recent_expenses.any? %>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Amount</th>
          <th>Category</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_expenses.each do |expense| %>
          <tr>
            <td><%= expense.title %></td>
            <td><%= expense.amount %></td>
            <td><%= expense.category.name %></td>
            <td><%= expense.expense_date %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No expenses recorded yet. <%= link_to "Add an expense", new_expense_path %></p>
  <% end %>
</div>

<%= link_to "View all Expenses", expenses_path %>